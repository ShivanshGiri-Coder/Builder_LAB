# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: optional for service role or webhooks — use only in Route Handlers / Server Actions
# SUPABASE_SERVICE_ROLE_KEY=

# Gemini API — keep on server only; call via Route Handlers, not the browser
# GEMINI_API_KEY=
